<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>Delivery Note <%= @po_code %></title>
<style>
  @page { size: A4; margin: 18mm 14mm; }
  * { box-sizing: border-box; }
  body { font: 11pt/1.4 -apple-system, "Helvetica Neue", Arial, sans-serif; color: #111; margin: 0; }
  header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #111; padding-bottom: 12px; }
  .from h1 { font-size: 13pt; margin: 0 0 4px 0; }
  .from .meta { font-size: 9.5pt; color: #444; white-space: pre-line; }
  .doc-block { text-align: right; }
  .doc-block h2 { font-size: 17pt; margin: 0; letter-spacing: 1px; text-transform: uppercase; }
  .doc-block .code { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 12pt; }

  section.parties { display: flex; gap: 24px; margin-top: 18px; }
  section.parties .col { flex: 1; }
  section.parties h3 { font-size: 9pt; text-transform: uppercase; letter-spacing: 0.8px; color: #666; margin: 0 0 6px 0; }
  section.parties .name { font-weight: 600; }
  section.parties .body { font-size: 10pt; white-space: pre-line; }

  table.lines { width: 100%; margin-top: 18px; border-collapse: collapse; font-size: 10pt; }
  table.lines th, table.lines td { padding: 8px; border-bottom: 1px solid #eee; vertical-align: top; }
  table.lines thead th { background: #f4f4f4; text-align: left; font-size: 9pt; text-transform: uppercase; letter-spacing: 0.5px; color: #555; }
  table.lines td.num, table.lines th.num { text-align: right; font-variant-numeric: tabular-nums; }
  .item-code { font-family: ui-monospace, "SF Mono", Menlo, monospace; font-size: 9.5pt; color: #555; }

  section.signoff { margin-top: 40px; display: flex; gap: 40px; }
  section.signoff .col { flex: 1; }
  section.signoff .line { border-top: 1px solid #777; margin-top: 50px; padding-top: 4px; font-size: 9pt; color: #555; }

  footer { margin-top: 26px; border-top: 1px solid #ddd; padding-top: 10px; font-size: 8.5pt; color: #777; display: flex; justify-content: space-between; }
</style>
</head>
<body>

<header>
  <div class="from">
    <h1><%= @company.name || "" %></h1>
    <div class="meta"><%= @company.legal_address || "" %><%= if @company.tax_number, do: "\nVAT " <> @company.tax_number, else: "" %></div>
  </div>
  <div class="doc-block">
    <h2>Delivery Note</h2>
    <div class="code"><%= @po_code %></div>
  </div>
</header>

<section class="parties">
  <div class="col">
    <h3>Vendor</h3>
    <div class="name"><%= (@vendor && @vendor.name) || "—" %></div>
    <div class="body"><%= (@vendor && @vendor.legal_address) || "" %></div>
  </div>
  <div class="col">
    <h3>Deliver to</h3>
    <div class="name"><%= @company.name || "" %></div>
    <div class="body"><%= @po.delivery_address || @company.legal_address || "" %></div>
  </div>
  <div class="col">
    <h3>Expected on</h3>
    <div class="name"><%= @format_date.(@po.expected_delivery_date) %></div>
    <div class="body">PO ref <%= @po_code %></div>
  </div>
</section>

<table class="lines">
  <thead>
    <tr>
      <th class="num" style="width: 24px;">#</th>
      <th>Item</th>
      <th class="num" style="width: 90px;">Qty ordered</th>
      <th class="num" style="width: 90px;">Qty delivered</th>
    </tr>
  </thead>
  <tbody>
    <%= for {l, idx} <- Enum.with_index(@lines, 1) do %>
      <tr>
        <td class="num"><%= idx %></td>
        <td>
          <div><%= (l.item && l.item.name) || "—" %></div>
          <div class="item-code"><%= @item_code.(l.item) %><%= if l.vendor_part_no, do: " · " <> l.vendor_part_no, else: "" %></div>
        </td>
        <td class="num"><%= @format_qty.(l.qty_ordered) %></td>
        <td class="num">&nbsp;</td>
      </tr>
    <% end %>
    <%= if @lines == [] do %>
      <tr><td colspan="4" style="color: #999; text-align: center; padding: 18px;">No lines on this PO.</td></tr>
    <% end %>
  </tbody>
</table>

<section class="signoff">
  <div class="col">
    <div class="line">Driver / vendor signature</div>
  </div>
  <div class="col">
    <div class="line">Goods-in signature</div>
  </div>
  <div class="col">
    <div class="line">Date received</div>
  </div>
</section>

<footer>
  <div><%= @company.name || "" %></div>
  <div>Generated <%= @now %></div>
</footer>

</body>
</html>
